# Optional: Gemini API key for real vision analysis
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: Google Lens via SerpApi (free plan available)
USE_GOOGLE_LENS=false
SERPAPI_API_KEY=

# Optional: App-to-backend auth (recommended for public deployment)
BACKEND_API_TOKEN=

# Optional: eBay API credentials for real sold search
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_REFRESH_TOKEN=
EBAY_ENVIRONMENT=sandbox
EBAY_MARKETPLACE_ID=EBAY_US

# Optional behavior flags
USE_REAL_EBAY=false
ALLOW_MOCK_FALLBACK=true
CACHE_TTL_HOURS=24
