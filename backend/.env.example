# Optional: Gemini API key for real vision analysis
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: Google Lens via SerpApi (free plan available)
USE_GOOGLE_LENS=false
SERPAPI_API_KEY=

# Optional: App-to-backend auth (recommended for public deployment)
BACKEND_API_TOKEN=

# Optional: eBay Marketplace Account Deletion notifications (production requirement)
EBAY_NOTIFICATION_VERIFICATION_TOKEN=
EBAY_NOTIFICATION_ENDPOINT_URL=

# Optional: eBay API credentials for real sold search
# You can keep one generic set OR both sandbox/production sets and switch via EBAY_ENVIRONMENT.
# To load shipping/return policy dropdowns, the refresh token must include:
# https://api.ebay.com/oauth/api_scope/sell.account.readonly
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_REFRESH_TOKEN=

# Optional: environment-specific credentials (preferred if you keep both keysets)
EBAY_SANDBOX_CLIENT_ID=
EBAY_SANDBOX_CLIENT_SECRET=
EBAY_SANDBOX_REDIRECT_URI=
EBAY_SANDBOX_REFRESH_TOKEN=
EBAY_SANDBOX_MARKETPLACE_ID=

EBAY_PRODUCTION_CLIENT_ID=
EBAY_PRODUCTION_CLIENT_SECRET=
EBAY_PRODUCTION_REDIRECT_URI=
EBAY_PRODUCTION_REFRESH_TOKEN=
EBAY_PRODUCTION_MARKETPLACE_ID=

EBAY_ENVIRONMENT=sandbox
EBAY_MARKETPLACE_ID=EBAY_US

# Optional behavior flags
USE_REAL_EBAY=false
ALLOW_MOCK_FALLBACK=true
CACHE_TTL_HOURS=24
